# =============================================================================
# A2P 環境変数テンプレート (docs/03 §5 全 29 項目)
# =============================================================================
# - 開発: このファイルをコピーして `.env.local` を作成
# - 本番: Railway Variables に同名で登録
# - シークレットは絶対に実値を git に commit しない (CLAUDE.md Hard Rule 6)
# - キーの追加/削除は `packages/contracts/src/env.ts` と同時に行うこと
#   (`tsx scripts/check-env-example.ts` が CI で差分を検出する)
# =============================================================================

# --- 1. 実行モード ---------------------------------------------------------
# development / test / production
NODE_ENV=development

# --- 2. DB -----------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@localhost:5432/a2p

# --- 3-5. 認証 / アプリ URL ------------------------------------------------
# 32 bytes hex (64 文字)。`openssl rand -hex 32` で生成
NEXTAUTH_SECRET=<64-hex-chars>
# 本番のみ必須。NextAuth コールバック URL
NEXTAUTH_URL=https://a2p.example.com
# フロントから参照可能な唯一の URL 変数 (メール本文リンク・2FA 承認 URL 等で使用)
NEXT_PUBLIC_APP_URL=https://a2p.example.com

# --- 6-7. シングルユーザー認証 ---------------------------------------------
AUTH_USERNAME=operator
# bcrypt 互換ハッシュ済みパスワード（bcryptjs 採用）。`node -e "console.log(require('bcryptjs').hashSync('PASSWORD', 12))"` で生成
AUTH_PASSWORD_HASH=<bcrypt-hash>

# --- 8-11. LLM プロバイダ --------------------------------------------------
# T-02-13 以降: 通常は UI (S-027) から DB に登録 (`ApiCredential`)。
# env は DB 未登録時のフォールバック。
# いずれも空文字でも未設定扱いになる (env zod preprocess)。
ANTHROPIC_API_KEY=sk-ant-<your-key>
OPENAI_API_KEY=sk-<your-key>
GOOGLE_GENERATIVE_AI_API_KEY=<your-key>
# 任意 (Phase 2+)。Anthropic 以外モデルでの Marketer Web 検索フォールバック。
# 空文字でも未設定扱いになる (env zod preprocess) ため値を入れない運用 OK
TAVILY_API_KEY=

# --- 12-16. R2 (オブジェクトストレージ) ------------------------------------
R2_ACCOUNT_ID=<hex>
R2_ACCESS_KEY_ID=<your-key-id>
R2_SECRET_ACCESS_KEY=<your-secret>
R2_BUCKET_NAME=a2p-artifacts
R2_PUBLIC_URL_BASE=https://<account>.r2.cloudflarestorage.com/<bucket>

# --- 17-19. メール (Resend) ------------------------------------------------
RESEND_API_KEY=re_<your-key>
MAIL_FROM=a2p@example.com
MAIL_TO=operator@example.com

# --- 20. KDP 認証情報暗号鍵 (Phase 3 必須) ---------------------------------
# 32 bytes hex (64 文字)。`openssl rand -hex 32` で生成
# 空文字でも未設定扱いになる (env zod preprocess) ため安心して値消去可
KDP_CRED_KEY=

# --- 20a. API 認証情報暗号鍵 (Phase 1 必須 / T-02-13) ----------------------
# UI から登録する LLM プロバイダ API キーの AES-256-GCM 暗号鍵。
# 32 bytes hex (64 文字)。`openssl rand -hex 32` で生成
# 空文字でも未設定扱いだが、DB 暗号化保存時に ConfigError になる
API_CRED_KEY=

# --- 21-22. 監視 / ログ -----------------------------------------------------
# 任意。未設定 (空文字も OK) なら Sentry 無効
SENTRY_DSN=
# 任意。fatal / error / warn / info / debug / trace (既定 info)
LOG_LEVEL=info

# --- 23-24. ワーカー並列度 -------------------------------------------------
# 任意 (既定 5)
WORKER_BOOK_CONCURRENCY=5
# 任意 (既定 4)
WORKER_CHAPTER_CONCURRENCY=4

# --- 25. 単価カタログ取得 cron --------------------------------------------
# 任意 (既定 `0 19 * * *` = JST 04:00 daily)
MODEL_CATALOG_FETCH_CRON=0 19 * * *

# --- 26. 為替 API -----------------------------------------------------------
# 任意 (既定 https://open.er-api.com/v6/latest/USD)
FX_RATE_API_URL=https://open.er-api.com/v6/latest/USD

# --- 27-28. コスト上限 (JPY) -----------------------------------------------
# 任意 (既定 500)
COST_LIMIT_PER_BOOK_JPY=500
# 任意 (既定 50000)
COST_LIMIT_MONTHLY_JPY=50000
