// packages/db/schema.prisma
// 全 31 model — docs/05 §3 から転記。手を入れる際は必ず docs/05 を同時更新すること。
// T-02-13 で ApiCredential (model #31) を追加。

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// 認証（単一ユーザー）
// =====================================================================
model User {
  id            String    @id @default(cuid())
  username      String    @unique
  password_hash String // bcrypt
  failed_count  Int       @default(0)
  locked_until  DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  auditLogs    AuditLog[]
  revisionRuns RevisionRun[]

  @@map("users")
}

// =====================================================================
// アカウント = KDP ペンネーム単位 [F-044/F-048]
// =====================================================================
model Account {
  id                  String   @id @default(cuid())
  pen_name            String
  display_name        String?
  bio                 String?
  target_reader       String?
  // type: { primary_genre: 'practical'|'business'|'self_help', ratio: Record<string, number>, focus_themes: string[] }
  genre_policy_json   Json
  kdp_credentials_enc String? // AES-256-GCM 暗号文 (Phase 3 用、Phase 1 は null)
  kdp_2fa_secret_enc  String? // TOTP シークレット（任意保管）
  status              String   @default("active") // active | archived
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  books           Book[]
  themeCandidates ThemeCandidate[]
  publishingPlans PublishingPlan[]
  salesFetchRuns  SalesFetchRun[]

  @@index([status], map: "accounts_status_idx")
  @@map("accounts")
}

// =====================================================================
// 長期出版プラン [F-002]
// =====================================================================
model PublishingPlan {
  id          String   @id @default(cuid())
  account_id  String
  period_from DateTime
  period_to   DateTime
  // type: { months: Array<{ ym: string; planned_count: number; theme_categories: string[]; series_candidates: string[] }> }
  plan_json   Json
  created_at  DateTime @default(now())

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id, period_from], map: "publishing_plans_account_period_idx")
  @@map("publishing_plans")
}

// =====================================================================
// テーマ候補 [F-001/F-017]
// =====================================================================
model ThemeCandidate {
  id               String    @id @default(cuid())
  account_id       String
  theme_session_id String // §14 設計判断 #6: 書籍未確定段階の token_usage 集計キー
  genre            String // practical | business | self_help
  title            String
  subtitle         String?
  hook             String // 差別化要素
  target_reader    String?
  // マスタから選択した著者名 / レーベル名 (任意)。表紙の著者名・出版レーベルに使用。
  author_name_id   String?
  label_name_id    String?
  // type: Array<{ asin?: string; title: string; url: string; rank?: number; review_summary?: string }>
  competitors_json Json
  // type: { search_volume?: number; rank_estimate?: number; sources: string[] }
  signals_json     Json
  status           String    @default("pending") // pending | accepted | rejected
  rejected_reason  String?
  created_at       DateTime  @default(now())
  decided_at       DateTime?

  account    Account     @relation(fields: [account_id], references: [id], onDelete: Cascade)
  authorName AuthorName? @relation(fields: [author_name_id], references: [id], onDelete: SetNull)
  labelName  LabelName?  @relation(fields: [label_name_id], references: [id], onDelete: SetNull)
  books      Book[]

  @@index([account_id, status, created_at], map: "theme_candidates_account_status_idx")
  @@index([theme_session_id], map: "theme_candidates_session_idx")
  @@index([author_name_id], map: "theme_candidates_author_name_idx")
  @@index([label_name_id], map: "theme_candidates_label_name_idx")
  @@map("theme_candidates")
}

// =====================================================================
// 著者名マスタ / レーベル名マスタ — テーマ作成時にプルダウンで選択する
// =====================================================================
model AuthorName {
  id          String   @id @default(cuid())
  name        String
  name_kana   String? // カタカナ読み (任意)
  name_romaji String? // ローマ字 (任意)
  note        String? // メモ (どんなジャンル向けか等)
  status      String   @default("active") // active | archived
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  themeCandidates ThemeCandidate[]

  @@index([status, name], map: "author_names_status_name_idx")
  @@map("author_names")
}

model LabelName {
  id         String   @id @default(cuid())
  name       String
  note       String? // メモ (ジャンル方針等)
  status     String   @default("active") // active | archived
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  themeCandidates ThemeCandidate[]

  @@index([status, name], map: "label_names_status_name_idx")
  @@map("label_names")
}

// =====================================================================
// 書籍 [F-010/F-016/F-033/F-042]
// =====================================================================
model Book {
  id                        String    @id @default(cuid())
  account_id                String
  theme_id                  String?
  title                     String
  subtitle                  String?
  asin                      String?   @unique
  // queued | running | editing | judging | thumbnail | exporting | done
  // | needs_human_review | failed | cancelled | paused_cost
  status                    String    @default("queued")
  cost_status               String    @default("normal") // normal | warn | paused | exceeded
  // Amazon KDP 出版ステータス (運営者が手動管理): unlisted=未対応 | published=出版済み
  publish_status            String    @default("unlisted")
  // [F-058] IG/TikTok 販促投稿に使う AI 生成画像の R2 キー (遅延生成・本ごとに再利用)。
  promo_image_key           String?
  cost_jpy_total            Decimal   @default(0) @db.Decimal(10, 2)
  // type: Record<role, prompt_id> このジョブ実行時の active バージョン
  prompt_version_ids_json   Json
  // type: Record<role, { provider, model, input_price, output_price }>
  model_assignment_snapshot Json
  has_pending_comments      Boolean   @default(false)
  has_blocking_comments     Boolean   @default(false) // F-049: must コメントが 1 件以上
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  done_at                   DateTime?

  account               Account                @relation(fields: [account_id], references: [id], onDelete: Cascade)
  theme                 ThemeCandidate?        @relation(fields: [theme_id], references: [id], onDelete: SetNull)
  outline               Outline?
  chapters              Chapter[]
  chapterRevisions      ChapterRevision[]
  covers                Cover[]
  coverTextProposals    CoverTextProposal[]
  kdpMetadata           KdpMetadata?
  kdpSubmissionProgress KdpSubmissionProgress?
  artifacts             Artifact[]
  jobs                  Job[]
  evalResults           EvalResult[]
  tokenUsages           TokenUsage[]
  salesRecords          SalesRecord[]
  revisionComments      RevisionComment[]
  batchPlanItems        BatchPlanItem[]
  promotionPlan         PromotionPlan?
  promotionPosts        PromotionPost[]
  orgTasks              OrgTask[]

  @@index([account_id, status, created_at(sort: Desc)], map: "books_account_status_idx")
  @@index([status, has_blocking_comments], map: "books_status_blocking_idx")
  @@index([cost_status], map: "books_cost_status_idx")
  @@map("books")
}

// =====================================================================
// 販促プラン [F-051] — 出版後に「売れる」ための AI 販促施策プラン (book と 1:1)
// =====================================================================
model PromotionPlan {
  id         String   @id @default(cuid())
  book_id    String   @unique
  // type: PromotionPlanOutput — { summary, pricing, category_keyword_actions[],
  //   review_actions[], launch_checklist[], promo_copy{ x_posts[], note_article, blog_outline }, ongoing_calendar[] }
  plan_json  Json
  status     String   @default("ready") // ready (生成済) | generating
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@map("promotion_plans")
}

// =====================================================================
// モデル・バエオフ [F-057] — 同一役割×同一入力を複数モデルで走らせ品質/コスト比較
// =====================================================================
model BakeoffRun {
  id          String   @id @default(cuid())
  role        String // 対象エージェントロール (writer/marketer/... )
  genre       String? // 対象ジャンル (null=既定)
  input_label String // 人が識別するためのラベル
  // type: { user: string; system_extra?: string } — 役割の active プロンプトに与える入力
  input_json  Json
  status      String   @default("queued") // queued | running | done | failed
  error       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  results BakeoffResult[]

  @@index([role, created_at(sort: Desc)])
  @@map("bakeoff_runs")
}

model BakeoffResult {
  id            String   @id @default(cuid())
  run_id        String
  provider      String
  model         String
  output_text   String?  @db.Text
  quality_score Int? // 0-100 (comparator 採点)
  rank          Int? // 1 = 最良
  rationale     String? // comparator の講評
  cost_jpy      Decimal? @db.Decimal(10, 4)
  latency_ms    Int?
  error         String?
  created_at    DateTime @default(now())

  run BakeoffRun @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id])
  @@map("bakeoff_results")
}

// =====================================================================
// 販促チャンネル設定 [F-052] — SNS / note / ブログの自動運用設定 (チャンネルと 1:1)
// =====================================================================
model PromotionChannelSetting {
  id           String   @id @default(cuid())
  channel      String   @unique // sns | note | blog
  // true のときだけ dispatcher が実投稿する。既定 false (誤爆防止)。
  auto_enabled Boolean  @default(false)
  // 表示用ハンドル/URL (例: @account, note ユーザ名, ブログ URL)。
  handle       String?
  // 投稿先アクセストークン等の暗号化保存 (AES-256-GCM, API_CRED_KEY)。未接続なら null。
  token_enc    String?  @db.Text
  token_mask   String? // 表示用マスク
  // チャンネル固有設定 (例: { webhook_url, api_base, default_hashtags[] })。
  config_json  Json?
  // [F-057] SNS アカウント運用設計。sns_strategist が生成し運営者が確認・適用する。
  // 表示名 (プロフィールに出す名前)。
  display_name         String?
  // AccountStrategyProfile (concept/bio/pillars/tone/cadence/hashtags/growth/画像プロンプト)。
  strategy_json        Json?
  // 生成済みアイコン (正方形) の R2 キー。未生成なら null。
  avatar_key           String?
  // 生成済みカバー/ヘッダー (横長) の R2 キー。未生成なら null。
  banner_key           String?
  // 戦略を最後に生成/更新した時刻。
  strategy_updated_at  DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("promotion_channel_settings")
}

// =====================================================================
// 販促アカウント台帳 [docs/06 P4] — チャンネル×アカウントの多アカウント運用
//   org(account_strategist)がジャンル/ターゲットの穴を分析し、必要なニッチ専用
//   アカウントを「戦略」として立案する。新規作成そのものは規約/KYC のため人手
//   (create_account=needs_human) だが、作成仕様(handle案/bio/投稿方針)まで org が埋める。
//   接続後は org が戦略に沿って投稿先を自動振り分けする(投稿ルーティングは後続増分)。
// =====================================================================
model PromotionAccount {
  id             String   @id @default(cuid())
  channel        String // x | instagram | tiktok | note | blog
  handle         String? // @handle / URL (接続後に確定)
  niche          String // このアカウントの切り口/ニッチ (戦略の核)
  target_reader  String? // 想定ターゲット読者
  bio            String?  @db.Text // 推奨プロフィール文 (作成仕様)
  posting_policy String?  @db.Text // 投稿方針/頻度 (作成仕様)
  // pending (要人手作成待ち) | connected (接続済・運用中) | archived
  status         String   @default("pending")
  // 接続後のトークン多重管理 (AES-256-GCM)。未接続なら null。
  token_enc      String?  @db.Text
  token_mask     String?
  config_json    Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  posts PromotionPost[]

  @@index([channel, status])
  @@map("promotion_accounts")
}

// =====================================================================
// 所有ブログ記事 [F-052b] — ツール自身が公開・運用するブログ (第三者接続不要で完全自律)
// =====================================================================
model BlogPost {
  id           String    @id @default(cuid())
  book_id      String?
  slug         String    @unique
  title        String
  body_md      String    @db.Text
  status       String    @default("published") // draft | published
  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([status, published_at(sort: Desc)])
  @@map("blog_posts")
}

// =====================================================================
// 販促投稿キュー [F-052] — 日程付きの投稿ドラフト。dispatcher が期限到来分を投稿する
// =====================================================================
model PromotionPost {
  id            String    @id @default(cuid())
  // [F-059] 育成(価値提供)投稿はどの本にも紐づかないため null 可。宣伝(promo)投稿は本に紐づく。
  book_id       String?
  channel       String // x | instagram | tiktok | note | blog
  // [F-059] 投稿種別: promo=宣伝(本の告知) | value=育成(価値提供・フォロワー獲得)。
  kind          String    @default("promo")
  // [F-060] 事前レンダリング済みメディア(TikTok 動画 mp4 等)の R2 キー。publish 時に署名URL化して添付。
  media_key     String?
  // P4 増分2: 投稿先の台帳アカウント (多アカウント routing)。null なら channel 既定設定を使う。
  account_id    String?
  title         String? // note/blog の見出し (SNS は null)
  body          String    @db.Text // 投稿本文 (SNS 文面 / note 記事 / ブログ骨子)
  scheduled_for DateTime // この時刻を過ぎたら投稿対象
  // draft | scheduled | posting | posted | failed | skipped | canceled
  status        String    @default("scheduled")
  external_url  String? // 投稿成功後の公開 URL
  error         String? // 投稿失敗時のメッセージ
  posted_at     DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  book    Book?             @relation(fields: [book_id], references: [id], onDelete: Cascade)
  account PromotionAccount? @relation(fields: [account_id], references: [id], onDelete: SetNull)

  @@index([status, scheduled_for])
  @@index([book_id])
  @@index([channel, status])
  @@map("promotion_posts")
}

// =====================================================================
// アウトライン [F-003/F-018]
// =====================================================================
model Outline {
  id            String    @id @default(cuid())
  book_id       String    @unique
  // type: Array<{ index: number; heading: string; summary: string; target_chars: number; subheadings: string[] }>
  chapters_json Json
  // type: OutlineReviewOutput — outline_review エージェントの章立て構成校正結果 (F-003b)。
  // { overall_ok, issues[], summary, revised_applied? }。null = 未レビュー。
  review_json   Json?
  status        String    @default("draft") // draft | pending_review | approved | rejected
  reject_note   String? // 差戻し時のコメント。Writer 再実行プロンプトに渡す
  approved_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([status], map: "outlines_status_idx")
  @@map("outlines")
}

// =====================================================================
// 章 [F-004] + 履歴
// =====================================================================
model Chapter {
  id         String   @id @default(cuid())
  book_id    String
  index      Int
  heading    String
  body_md    String   @db.Text
  status     String   @default("draft") // draft | done | failed
  char_count Int      @default(0)
  version    Int      @default(1) // 修正反映で +1
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  book      Book              @relation(fields: [book_id], references: [id], onDelete: Cascade)
  revisions ChapterRevision[]

  @@unique([book_id, index], map: "chapters_book_index_key")
  @@index([book_id, status], map: "chapters_book_status_idx")
  @@map("chapters")
}

// 章の旧版退避（F-050 ロールバック用）
model ChapterRevision {
  id         String   @id @default(cuid())
  chapter_id String
  book_id    String
  version    Int
  body_md    String   @db.Text
  reason     String // "revision_run:<run_id>" | "manual_edit" 等
  created_at DateTime @default(now())

  chapter Chapter @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  book    Book    @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([chapter_id, version(sort: Desc)], map: "chapter_revisions_chapter_version_idx")
  @@map("chapter_revisions")
}

// =====================================================================
// カバー [F-006/F-007/F-014/F-019]
// =====================================================================
model CoverTextProposal {
  id         String   @id @default(cuid())
  book_id    String
  title      String
  subtitle   String?
  band_copy  String? // 帯文
  status     String   @default("proposed") // proposed | adopted | rejected
  created_at DateTime @default(now())

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([book_id, status], map: "cover_text_proposals_book_status_idx")
  @@map("cover_text_proposals")
}

model Cover {
  id                   String   @id @default(cuid())
  book_id              String
  cover_text_id        String?
  r2_key               String // 原画像 R2 キー
  artifact_id          String? // KDP 寸法 PNG 出力後の Artifact ID
  prompt_used          String   @db.Text
  width                Int
  height               Int
  status               String   @default("generated") // generated | adopted | rejected
  // type: { provider: 'openai', model: 'gpt-image-1', cost_jpy: number }
  generation_meta_json Json
  created_at           DateTime @default(now())

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([book_id, status], map: "covers_book_status_idx")
  @@map("covers")
}

// =====================================================================
// KDP メタデータ [F-040]
// =====================================================================
model KdpMetadata {
  id              String   @id @default(cuid())
  book_id         String   @unique
  description     String   @db.Text
  categories      String[] // KDP 2 カテゴリ
  keywords        String[] // 最大 7 個
  price_jpy       Int
  // KDP 入稿用フリガナ/ローマ字 (F-020b)。AI 生成カタカナ + ローマ字自動変換。null=未生成。
  title_kana      String?
  title_romaji    String?
  subtitle_kana   String?
  subtitle_romaji String?
  author_kana     String?
  author_romaji   String?
  // [F-020c] レーベル名の読み (KDP 入稿の出版社/レーベル欄)。label 名はテーマの LabelName マスタ由来。
  label_kana      String?
  label_romaji    String?
  // [F-020c] シリーズ名 (任意。KDP のシリーズ欄。未設定なら空)。
  series_name     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@map("kdp_metadata")
}

// =====================================================================
// KDP 入稿チェックリスト [F-020] / 自動入稿進捗 [F-041 Phase 3]
// =====================================================================
model KdpSubmissionProgress {
  id                      String    @id @default(cuid())
  book_id                 String    @unique
  // type: Record<field, { copied: boolean; checked: boolean; checked_at?: string }>
  checklist_state_json    Json
  // null | queued | logging_in | inputting | uploading | pricing | awaiting_2fa | publish_pending | done | failed
  auto_submit_status      String?
  auto_submit_started_at  DateTime?
  auto_submit_finished_at DateTime?
  last_error              String?
  screenshot_r2_keys      String[] // 失敗時スクショ
  submitted_at            DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@map("kdp_submission_progress")
}

// KDP 2FA コード受け渡し [KDP-03 Phase 3]
model Kdp2FaCode {
  id           String    @id @default(cuid())
  job_id       String    @unique // graphile-worker のジョブ ID と紐付け
  status       String    @default("awaiting") // awaiting | submitted | timeout
  code         String? // 運営者入力
  requested_at DateTime  @default(now())
  submitted_at DateTime?
  timeout_at   DateTime // 既定 +10 分

  @@index([status, timeout_at], map: "kdp_2fa_codes_status_timeout_idx")
  @@map("kdp_2fa_codes")
}

// =====================================================================
// 成果物 [F-012〜F-015]
// =====================================================================
model Artifact {
  id         String   @id @default(cuid())
  book_id    String
  kind       String // docx | pdf | png_cover | md_source | kdp_screenshot
  r2_key     String   @unique
  byte_size  Int
  checksum   String // sha256 hex
  created_at DateTime @default(now())

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([book_id, kind], map: "artifacts_book_kind_idx")
  @@map("artifacts")
}

// =====================================================================
// ジョブ実行ログ（graphile-worker とは別に業務用ジョブを記録） [F-010/F-016/F-045/F-046]
// =====================================================================
model Job {
  id              String    @id @default(cuid())
  graphile_job_id BigInt? // graphile_worker.jobs.id への参照（worker 側で確定後に書き戻し）
  kind            String // task_identifier と同じ
  book_id         String?
  parent_job_id   String?
  status          String    @default("queued") // queued | running | done | failed | cancelled
  payload_json    Json
  result_json     Json?
  error           String?   @db.Text
  retries         Int       @default(0)
  started_at      DateTime?
  finished_at     DateTime?
  created_at      DateTime  @default(now())

  book        Book?        @relation(fields: [book_id], references: [id], onDelete: SetNull)
  parent      Job?         @relation("JobParent", fields: [parent_job_id], references: [id], onDelete: SetNull)
  children    Job[]        @relation("JobParent")
  tokenUsages TokenUsage[]

  @@index([status, kind, created_at(sort: Desc)], map: "jobs_status_kind_idx")
  @@index([book_id, kind], map: "jobs_book_kind_idx")
  @@map("jobs")
}

// =====================================================================
// 夜間バッチ計画 [F-021]
// =====================================================================
model BatchPlan {
  id                 String    @id @default(cuid())
  planned_at         DateTime
  concurrency        Int       @default(5)
  deadline           DateTime?
  predicted_cost_jpy Int
  status             String    @default("scheduled") // scheduled | running | done | failed | cancelled
  kicked_at          DateTime?
  created_at         DateTime  @default(now())

  items BatchPlanItem[]

  @@index([status, planned_at], map: "batch_plans_status_planned_idx")
  @@map("batch_plans")
}

model BatchPlanItem {
  id                              String  @id @default(cuid())
  batch_id                        String
  theme_id                        String? // 採用テーマ
  book_id                         String? // キック後に紐付け
  // type: Record<role, { provider, model }> | null
  override_model_assignments_json Json?
  status                          String  @default("pending") // pending | kicked | failed

  batch BatchPlan @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  book  Book?     @relation(fields: [book_id], references: [id], onDelete: SetNull)

  @@index([batch_id], map: "batch_plan_items_batch_idx")
  @@map("batch_plan_items")
}

// =====================================================================
// モデルカタログ [F-024/F-025]
// =====================================================================
model ModelCatalog {
  id                        String   @id @default(cuid())
  provider                  String // anthropic | openai | google
  model                     String // claude-opus-4-7 等
  input_price_per_mtok_usd  Decimal  @db.Decimal(10, 6)
  output_price_per_mtok_usd Decimal  @db.Decimal(10, 6)
  image_price_per_image_usd Decimal? @db.Decimal(10, 6)
  fx_rate_usd_jpy           Decimal  @db.Decimal(10, 4)
  fetched_at                DateTime @default(now())
  source                    String // "anthropic_pricing_page_v1" | "openai_pricing_v2" | "manual_edit"
  raw_json                  Json
  is_current                Boolean  @default(true)

  @@unique([provider, model, fetched_at], map: "model_catalog_provider_model_time_key")
  @@index([is_current, provider], map: "model_catalog_current_idx")
  @@map("model_catalog")
}

// =====================================================================
// モデル割当 [F-022/F-023]
// =====================================================================
model ModelAssignment {
  id           String    @id @default(cuid())
  role         String // marketer | writer | editor | judge | thumbnail_text | thumbnail_image | optimizer
  genre        String? // null = 全ジャンル既定
  provider     String
  model        String
  status       String    @default("active") // active | archived
  activated_at DateTime  @default(now())
  archived_at  DateTime?
  created_by   String // user_id

  // パーシャル UNIQUE: status='active' の組合せは 1 つに制限（手書きマイグレーションで設定）
  @@index([role, genre, status], map: "model_assignments_role_genre_status_idx")
  @@index([role, genre, activated_at(sort: Desc)], map: "model_assignments_role_genre_time_idx")
  @@map("model_assignments")
}

// =====================================================================
// プロンプト管理 [F-027〜F-031]
// =====================================================================
model Prompt {
  id                String    @id @default(cuid())
  role              String
  genre             String? // null = 役割デフォルト
  version           Int
  body              String    @db.Text
  // type: string[]  例: ["title", "chapter_outline"]
  placeholders_json Json
  status            String    @default("active") // active | archived
  created_by        String // "human" | "optimizer:<proposal_id>"
  activated_at      DateTime?
  archived_at       DateTime?
  created_at        DateTime  @default(now())

  proposals PromptProposal[] @relation("PromptProposalSource")

  @@unique([role, genre, version], map: "prompts_role_genre_version_key")
  // パーシャル UNIQUE: status='active' は 1 つに制限（手書きマイグレーション）
  @@index([role, genre, status], map: "prompts_role_genre_status_idx")
  @@index([role, genre, version(sort: Desc)], map: "prompts_role_genre_ver_idx")
  @@map("prompts")
}

model PromptProposal {
  id                   String    @id @default(cuid())
  source_prompt_id     String // 旧版
  role                 String
  genre                String?
  proposed_body        String    @db.Text
  diff                 String    @db.Text
  rationale            String    @db.Text
  // type: { score_delta?: number; sales_delta_pct?: number }
  expected_effect_json Json
  sample_output        String?   @db.Text
  status               String    @default("pending") // pending | approved | rejected | auto_approved
  decided_by           String? // user_id or "auto"
  decided_at           DateTime?
  rejection_note       String?
  rollback_until       DateTime? // 自動承認時の 24h ロールバック猶予
  created_at           DateTime  @default(now())

  sourcePrompt Prompt @relation("PromptProposalSource", fields: [source_prompt_id], references: [id], onDelete: Cascade)

  @@index([status, created_at(sort: Desc)], map: "prompt_proposals_status_idx")
  @@map("prompt_proposals")
}

// =====================================================================
// 評価結果 [F-008/F-009/F-030]
// =====================================================================
model EvalResult {
  id                      String   @id @default(cuid())
  book_id                 String
  // type: Record<role, prompt_id> 採点対象の生成時バージョン
  prompt_version_ids_json Json
  score_total             Int // 0..100
  // type: { benefit_clarity, logical_consistency, style_consistency, japanese_naturalness, title_alignment, genre_fit: number }
  score_breakdown_json    Json
  // type: Record<axis, string>
  judge_comments_json     Json
  triggered_by            String // "auto" | "manual" | "revision_run:<id>"
  retry_count             Int      @default(0)
  judged_at               DateTime @default(now())

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([book_id, judged_at(sort: Desc)], map: "eval_results_book_time_idx")
  @@index([judged_at(sort: Desc)], map: "eval_results_time_idx")
  @@map("eval_results")
}

// =====================================================================
// トークン使用量 [F-032〜F-035] — 観測の中心
// =====================================================================
model TokenUsage {
  id                  String   @id @default(cuid())
  book_id             String? // nullable: テーマ生成段階等
  theme_session_id    String? // book_id 未確定時の集計キー
  job_id              String?
  org_task_id         String? // docs/06 §9: 組織タスク別コスト集計キー (CEO/本部長/担当の呼出)
  provider            String // anthropic | openai | google
  model               String
  role                String // marketer | writer | editor | judge | thumbnail_text | thumbnail_image | optimizer | revision
  input_tokens        Int      @default(0)
  output_tokens       Int      @default(0)
  cached_input_tokens Int      @default(0) // Prompt Caching 利用時の節約分
  image_count         Int      @default(0)
  // type: { input_per_mtok_usd, output_per_mtok_usd, image_per_image_usd?, fx_rate_usd_jpy }
  unit_price_snapshot Json
  cost_jpy            Decimal  @db.Decimal(10, 4)
  created_at          DateTime @default(now())

  book Book? @relation(fields: [book_id], references: [id], onDelete: SetNull)
  job  Job?  @relation(fields: [job_id], references: [id], onDelete: SetNull)

  @@index([book_id, created_at], map: "token_usage_book_time_idx")
  @@index([theme_session_id], map: "token_usage_session_idx")
  @@index([org_task_id], map: "token_usage_org_task_idx")
  @@index([provider, model, created_at], map: "token_usage_provider_model_idx")
  @@index([role, created_at], map: "token_usage_role_idx")
  @@index([created_at(sort: Desc)], map: "token_usage_time_idx") // 月次集計
  @@map("token_usage")
}

// =====================================================================
// 売上 [F-037/F-038/F-039]
// =====================================================================
model SalesRecord {
  id           String   @id @default(cuid())
  book_id      String
  year_month   String // "2026-05"
  royalty_jpy  Int
  review_count Int      @default(0)
  avg_stars    Decimal? @db.Decimal(3, 2)
  bsr          Int? // Amazon Best Seller Rank
  source       String // manual | auto
  fetched_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@unique([book_id, year_month], map: "sales_records_book_month_key")
  @@index([year_month], map: "sales_records_month_idx")
  @@index([book_id], map: "sales_records_book_id_idx")
  @@map("sales_records")
}

// =====================================================================
// 売上自動取得実行履歴 [F-038]
// =====================================================================
model SalesFetchRun {
  id               String    @id @default(cuid())
  account_id       String
  year_month       String // "2026-05"
  status           String    @default("running") // running | done | failed | 2fa_waiting
  records_upserted Int       @default(0)
  error_message    String?
  started_at       DateTime  @default(now())
  finished_at      DateTime?

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id, started_at(sort: Desc)], map: "sales_fetch_runs_account_time_idx")
  @@index([status, started_at(sort: Desc)], map: "sales_fetch_runs_status_time_idx")
  @@map("sales_fetch_runs")
}

// =====================================================================
// アラート [F-024/F-034/F-036]
// =====================================================================
model Alert {
  id           String    @id @default(cuid())
  kind         String // cost_per_book_warn | cost_per_book_pause | monthly_cost_80 | monthly_cost_95 | monthly_cost_100 | catalog_price_change | job_failed_3times | catalog_fetch_failed | fx_fetch_failed | revision_run_failed
  severity     String // info | warning | critical
  payload_json Json
  read_at      DateTime?
  resolved_at  DateTime?
  created_at   DateTime  @default(now())

  @@index([resolved_at, created_at(sort: Desc)], map: "alerts_resolved_time_idx")
  @@index([kind, created_at(sort: Desc)], map: "alerts_kind_time_idx")
  @@map("alerts")
}

// =====================================================================
// 監査ログ [F-029/F-030/F-046]
// =====================================================================
model AuditLog {
  id          String   @id @default(cuid())
  actor_id    String? // user_id, "system", "optimizer"
  action      String // prompt.approve | prompt.rollback | model_assignment.change | job.retry | job.cancel | revision_run.kick | settings.update
  target_kind String
  target_id   String
  before_json Json?
  after_json  Json?
  created_at  DateTime @default(now())

  actor User? @relation(fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([created_at(sort: Desc)], map: "audit_log_time_idx")
  @@index([target_kind, target_id], map: "audit_log_target_idx")
  @@map("audit_log")
}

// =====================================================================
// 修正コメント [F-049]
// =====================================================================
model RevisionComment {
  id                      String    @id @default(cuid())
  book_id                 String
  target_kind             String // chapter | outline | cover | cover_text | metadata | theme
  target_id               String
  // type: { paragraph_range?: [number, number]; line_range?: [number, number]; image_region?: { x, y, w, h } } | null
  range_json              Json?
  body                    String    @db.Text
  priority                String // must | should | may
  status                  String    @default("pending") // pending | applied | not_applicable | superseded
  run_id                  String?
  // type: { reason?: string; new_target_id?: string; diff_summary?: string }
  application_result_json Json?
  created_by              String // user_id
  created_at              DateTime  @default(now())
  applied_at              DateTime?

  book Book         @relation(fields: [book_id], references: [id], onDelete: Cascade)
  run  RevisionRun? @relation(fields: [run_id], references: [id], onDelete: SetNull)

  @@index([book_id, status, priority], map: "revision_comments_book_status_idx")
  @@index([status, created_at], map: "revision_comments_status_time_idx")
  @@index([target_kind, target_id], map: "revision_comments_target_idx")
  @@map("revision_comments")
}

// =====================================================================
// 修正一括反映実行 [F-050]
// =====================================================================
model RevisionRun {
  id                  String    @id @default(cuid())
  triggered_by        String // user_id
  triggered_at        DateTime  @default(now())
  started_at          DateTime?
  finished_at         DateTime?
  status              String    @default("queued") // queued | running | done | failed | partial
  // type: string[]
  book_ids_json       Json
  // type: string[]
  comment_ids_json    Json
  // type: { applied: number; not_applicable: number; failed: number; cost_jpy: number; rescore_delta?: number; blocked_books?: string[] }
  result_summary_json Json?
  error               String?   @db.Text

  triggeredByUser User              @relation(fields: [triggered_by], references: [id], onDelete: NoAction)
  comments        RevisionComment[]

  @@index([status, triggered_at(sort: Desc)], map: "revision_runs_status_time_idx")
  @@map("revision_runs")
}

// =====================================================================
// 書籍単位の排他制御ロック [§14 設計判断 #4]
// =====================================================================
model BookLock {
  book_id     String   @id
  holder      String // "revision_run:<id>" | "pipeline:<job_id>" | "kdp_submit:<job_id>"
  acquired_at DateTime @default(now())
  expires_at  DateTime // 既定 +30 分（タスクタイムアウトと整合）

  @@index([expires_at], map: "book_locks_expires_idx")
  @@map("book_locks")
}

// =====================================================================
// API 認証情報 (F-051/F-052) — UI から登録する LLM プロバイダキーの暗号化保存
// =====================================================================
model ApiCredential {
  id                    String    @id @default(cuid())
  provider              String    @unique // anthropic | openai | google
  key_enc               String    @db.Text // AES-256-GCM (API_CRED_KEY)
  key_mask              String // 表示用マスク "sk-…AbCd"
  set_at                DateTime  @default(now())
  set_by                String // User.id
  last_tested_at        DateTime?
  // type: { ok: boolean; message: string; http_status?: number; latency_ms?: number }
  last_test_result_json Json?

  @@map("api_credentials")
}

// =====================================================================
// コスト改善提案（F-062）— 週次でコスト分析エージェントが生成、承認で executor が実行
// =====================================================================
model CostImprovementProposal {
  id                   String    @id @default(cuid())
  batch_id             String // 週次実行のグルーピング
  category             String // model | cadence | feature | other
  title                String
  description          String    @db.Text
  estimated_saving_jpy Int       @default(0) // 月あたり推定削減額
  impact_note          String    @db.Text // 影響/リスク
  action_kind          String // switch_model_assignment | set_app_setting | advisory
  // type: switch_model_assignment={role,genre?,provider,model} / set_app_setting={key,value}
  action_params_json   Json
  status               String    @default("proposed") // proposed | approved | applied | dismissed | failed
  applied_at           DateTime?
  apply_result         String?   @db.Text
  created_at           DateTime  @default(now())

  @@index([status, created_at(sort: Desc)], map: "cost_proposals_status_time_idx")
  @@map("cost_improvement_proposals")
}

// =====================================================================
// アプリ設定（S-027 単一行） [F-030/F-034/F-036/F-038]
// =====================================================================
model AppSettings {
  id                              String   @id @default("singleton")
  notification_email_to           String
  // type: Record<AlertKind, boolean>
  notification_kinds_json         Json
  cost_per_book_warn_jpy          Int      @default(500)
  cost_per_book_pause_jpy         Int      @default(750)
  monthly_cost_yellow_jpy         Int      @default(40000)
  monthly_cost_orange_jpy         Int      @default(47500)
  monthly_cost_red_jpy            Int      @default(50000)
  monthly_budget_exceeded         Boolean  @default(false) // T-07-03: 100% 到達で true、翌月初に reset
  force_continue                  Boolean  @default(false) // T-07-03: 運営者が強制続行を許可
  catalog_price_change_threshold  Decimal  @default(0.10) @db.Decimal(4, 3) // ±10%
  prompt_auto_approval_enabled    Boolean  @default(false)
  prompt_auto_approval_rollback_h Int      @default(24)
  sales_auto_fetch_enabled        Boolean  @default(false)
  sales_auto_fetch_cron           String   @default("0 17 * * *") // 02:00 JST
  // F-052: 販促自動運用。入稿(publish)で販促プランを自動立案し投稿キューを自動生成するか。
  promo_auto_on_publish_enabled   Boolean  @default(false)
  // F-052: 期限到来した投稿を自動投稿するディスパッチャ cron を有効化するマスタスイッチ。
  promo_auto_post_enabled         Boolean  @default(false)
  promo_dispatch_cron             String   @default("*/30 * * * *") // 30分毎に期限到来分をチェック
  // F-061: 日次で予定投稿の本文を content_optimizer が見直す機能のマスタスイッチ。
  promo_daily_review_enabled      Boolean  @default(false)
  promo_review_cron               String   @default("0 23 * * *") // JST 08:00 に予定投稿を見直し
  // F-062: 週次でコスト改善提案を生成する機能のマスタスイッチ。
  cost_auto_analyze_enabled       Boolean  @default(false)
  cost_analyze_cron               String   @default("0 20 * * 1") // 毎週月曜 05:00 JST にコスト分析
  kdp_submit_timeout_minutes      Int      @default(10)
  kdp_submit_retry_count          Int      @default(2)
  job_log_retention_days          Int      @default(90)
  r2_archive_threshold_days       Int      @default(365) // T-07-09: R2 アーカイブログ保持日数
  ai_disclosure_text              String   @db.Text // F-005 巻末挿入文
  // T-02-08: fx.fetch (B-04) が日次更新する USD/JPY 為替レート。
  // catalog.fetch (T-02-09) が `fx_rate_usd_jpy` として参照する。初回 fetch 前は null。
  latest_fx_rate                  Decimal? @db.Decimal(10, 4)
  // T-11-06: A/B 配信設定。type: Array<{ role, genre, baseline_id, candidate_id, ratio_candidate }>
  ab_distribution_json            Json?
  // docs/06: 組織エージェント。CEOティック(org.plan)を日次cronで自動起動するか。
  org_auto_plan_enabled           Boolean  @default(false)
  org_plan_cron                   String   @default("0 20 * * *") // 05:00 JST (UTC 20:00)
  // docs/06 P2: 承認済 org_tasks を担当者が自動実行する dispatcher(org.execute.dispatch)を cron 有効化するか。
  org_auto_execute_enabled        Boolean  @default(false)
  org_execute_cron                String   @default("*/15 * * * *") // 15分毎に承認済タスクをディスパッチ
  // docs/06 P3: 運用の自己復旧監視(org.ops.watch)を cron 有効化するか。
  org_ops_watch_enabled           Boolean  @default(false)
  org_ops_watch_cron              String   @default("*/10 * * * *") // 10分毎にジョブ健全性を走査
  // docs/06 P3: 経営の予算ガード(org.finance.tick)を cron 有効化するか。
  org_finance_tick_enabled        Boolean  @default(false)
  org_finance_tick_cron           String   @default("0 * * * *") // 毎時、本部別コスト集計＋予算ガード
  // docs/06 P4 増分3: KDP 公開の事前スクリーニング(org.kdp.screen)を cron 有効化＋
  // 合格書籍を自動で承認済(公開クリア)へ前進させるゲート。既定OFF（誤公開防止）。
  // 実際の外部入稿(kdp.submit, Playwright)は Phase 3 まで人手のまま。
  org_kdp_auto_publish_enabled    Boolean  @default(false)
  org_kdp_screen_cron             String   @default("30 * * * *") // 毎時30分、公開レディを事前審査
  org_kdp_min_quality             Int      @default(70) // 公開に必要な最低品質スコア(0..100)
  org_kdp_min_price_jpy           Int      @default(250) // 許容価格帯の下限
  org_kdp_max_price_jpy           Int      @default(1250) // 許容価格帯の上限
  updated_at                      DateTime @updatedAt

  @@map("app_settings")
}

// =====================================================================
// 組織エージェント [docs/06] — CEO → 本部長 → 担当者 ＋ 全社ToDoバックログ
// =====================================================================

/// CEO の方針（全社戦略）。期間ごとに 1 本のアクティブな Objective を持つ。
model OrgObjective {
  id                     String   @id @default(cuid())
  period_label           String // "2026-07" | "launch:bookX"
  title                  String
  // type: { focus_books: string[]; goals: string[]; kpi: string[]; notes?: string }
  body_json              Json
  budget_jpy             Int? // この方針の全社コスト上限
  // type: Partial<Record<Division, number>> 本部別予算配分
  budget_allocation_json Json?
  status                 String   @default("active") // active | closed
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  tasks OrgTask[]

  @@index([status, created_at(sort: Desc)], map: "org_objectives_status_time_idx")
  @@map("org_objectives")
}

/// 全社ToDoバックログ本体。全 Org エージェントはここを介して協働する。
model OrgTask {
  id            String    @id @default(cuid())
  objective_id  String?
  parent_id     String?
  division      String // production | publishing | analytics | promotion | sysops | finance
  book_id       String?
  owner_role    String // 起票者ロール (ceo | *_mgr | analyst 等)
  assignee_role String // 実行担当ロール (writer | metadata_worker | content_creator | human 等)
  channel       String? // 販促用: x | instagram | tiktok | note | blog
  account_ref   String? // 販促用: 対象アカウント識別
  theme_id      String? // 制作 write: 起動元テーマ候補 ID (dispatcher が kickoff に使う)
  account_id    String? // 制作: 発注 KDP アカウント (省略時は dispatcher が既定を解決)
  kind          String // docs/06 §6 の本部別動詞
  title         String
  instruction   String    @db.Text
  status        String    @default("proposed") // proposed|approved|in_progress|blocked|needs_human|done|canceled
  priority      String    @default("should") // must | should | may
  // type: string[] 依存タスクID
  depends_on    String[]  @default([])
  scheduled_for DateTime?
  cost_jpy      Decimal?  @db.Decimal(10, 4)
  // type: 実行成果 (生成物ID/ASIN/投稿URL/検証結果 等)
  result_json   Json?
  error         String?   @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  done_at       DateTime?

  objective OrgObjective? @relation(fields: [objective_id], references: [id], onDelete: SetNull)
  parent    OrgTask?      @relation("OrgTaskChildren", fields: [parent_id], references: [id], onDelete: SetNull)
  children  OrgTask[]     @relation("OrgTaskChildren")
  book      Book?         @relation(fields: [book_id], references: [id], onDelete: SetNull)

  @@index([status, scheduled_for], map: "org_tasks_status_sched_idx")
  @@index([division, status], map: "org_tasks_division_status_idx")
  @@index([book_id], map: "org_tasks_book_idx")
  @@index([assignee_role, status], map: "org_tasks_assignee_status_idx")
  @@index([objective_id], map: "org_tasks_objective_idx")
  @@map("org_tasks")
}

/// 勝ちパターン台帳（P4 増分4）。org.plan が毎ティック、実績から抽出した「効いている型」を
/// 蓄積し、CEO の意思決定に供給する。singleton（最新の学習知見を保持）。
model OrgPlaybook {
  id            String   @id @default("singleton")
  // type: WinningPatterns { top_genres[], underexposed_genres[], insights[] }
  patterns_json Json
  updated_at    DateTime @updatedAt

  @@map("org_playbook")
}
