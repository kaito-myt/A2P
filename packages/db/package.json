{
  "name": "@a2p/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./cost-aggregation": "./src/cost-aggregation.ts",
    "./books-kpi": "./src/books-kpi.ts",
    "./ab-comparison": "./src/ab-comparison.ts"
  },
  "scripts": {
    "postinstall": "prisma generate --schema=./schema.prisma",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "prisma": "prisma",
    "format": "prisma format --schema=./schema.prisma",
    "validate": "prisma validate --schema=./schema.prisma",
    "generate": "prisma generate --schema=./schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=./schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=./schema.prisma",
    "migrate:reset": "prisma migrate reset --schema=./schema.prisma --force",
    "studio": "prisma studio --schema=./schema.prisma",
    "seed": "tsx seed.ts"
  },
  "prisma": {
    "seed": "tsx seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
